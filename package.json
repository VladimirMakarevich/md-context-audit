{
  "name": "md-context-audit",
  "version": "0.0.0",
  "private": true,
  "description": "CLI for auditing Markdown context in repositories.",
  "type": "module",
  "bin": {
    "md-context-audit": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24.17.0 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "prepack": "npm run build"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "micromatch": "^4.0.8",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  }
}
